{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python /absolute/path/to/Claude-Code-Mapper/codemap_hook.py session"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python /absolute/path/to/Claude-Code-Mapper/codemap_hook.py pre"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python /absolute/path/to/Claude-Code-Mapper/codemap_hook.py post"
          }
        ]
      }
    ]
  }
}
